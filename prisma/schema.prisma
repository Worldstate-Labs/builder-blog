// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                      String                   @id @default(cuid())
  name                    String?
  email                   String?                  @unique
  emailVerified           DateTime?
  image                   String?
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
  accounts                Account[]
  sessions                Session[]
  subscriptions           Subscription[]
  digests                 Digest[]
  agentTokens             AgentToken[]
  personalBuilders        Builder[]                @relation("PersonalBuilders")
  builderPoolEntries      BuilderPoolEntry[]
  libraryHubEntries       LibraryHubEntry[]
  libraryImports          LibraryImport[]
  digestPipelineShares    DigestPipelineShare[]
  digestPipelineImports   DigestPipelineImport[]
  feedPreference          UserFeedPreference?
  feedReads               FeedRead[]
  feedFavorites           FeedFavorite[]
  digestedItems           DigestedItem[]
  recommendationSnapshots RecommendationSnapshot[]
  channelPreferences      UserChannelPreference[]
  libraryVisibilities     UserLibraryVisibility[]
  libraryFetchRuns        LibraryFetchRun[]
  agentJobRuns            AgentJobRun[]
  libraryCronJob          LibraryCronJob?
  digestCronJob           DigestCronJob?
  digestRuns              DigestRun[]
  sourceTypeConfigs       UserSourceTypeConfig[]
  digestConfig            UserDigestConfig?
}

model LibraryFetchRun {
  id                String   @id @default(cuid())
  userId            String
  startedAt         DateTime
  finishedAt        DateTime
  durationMs        Int
  status            String
  source            String
  cliVersion        String?
  hostname          String?
  platform          String?
  buildersAttempted Int      @default(0)
  itemsFetched      Int      @default(0)
  tasksGenerated    Int      @default(0)
  userActionsCount  Int      @default(0)
  errorCount        Int      @default(0)
  summary           String
  details           Json
  jobRunId          String?
  createdAt         DateTime @default(now())
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, startedAt(sort: Desc)])
  @@index([userId, jobRunId])
}

model AgentJobRun {
  id          String    @id @default(cuid())
  userId      String
  jobType     String
  trigger     String
  scheduleJob String?
  instanceId  String
  expectedAt  DateTime?
  startedAt   DateTime
  heartbeatAt DateTime?
  finishedAt  DateTime?
  status      String
  exitCode    Int?
  signal      String?
  runtime     String?
  runnerPid   Int?
  workerPid   Int?
  hostname    String?
  platform    String?
  stage       String?
  summary     String?
  details     Json      @default("{}")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, instanceId])
  @@index([userId, jobType, startedAt(sort: Desc)])
  @@index([userId, scheduleJob, expectedAt(sort: Desc)])
  @@index([userId, status])
}

model LibraryCronJob {
  id              String    @id @default(cuid())
  userId          String    @unique
  status          String    @default("active")
  startedAt       DateTime
  stoppedAt       DateTime?
  frequencyKey    String
  frequencyLabel  String
  schedule        String
  intervalMinutes Int
  runtime         String?
  overrideFetched Boolean   @default(false)
  hostname        String?
  platform        String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
}

model DigestCronJob {
  id               String    @id @default(cuid())
  userId           String    @unique
  status           String    @default("active")
  startedAt        DateTime
  stoppedAt        DateTime?
  frequencyKey     String
  frequencyLabel   String
  schedule         String
  intervalMinutes  Int
  runtime          String?
  regenerateDigest Boolean   @default(false)
  hostname         String?
  platform         String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Builder {
  id            String                  @id @default(cuid())
  ownerUserId   String
  kind          BuilderKind             @default(X)
  name          String
  handle        String?
  canonicalKey  String
  libraryKey    String                  @unique
  sourceType    String                  @default("auto")
  sourceUrl     String?
  fetchUrl      String?
  avatarUrl     String?
  avatarDataUrl String?
  bio           String?
  addedByUserId String?
  entityId      String
  lastFetchedAt DateTime?
  lastForcedAt  DateTime?
  itemCount     Int                     @default(0)
  status        FetchStatus             @default(IDLE)
  lastError     String?
  createdAt     DateTime                @default(now())
  updatedAt     DateTime                @updatedAt
  owner         User                    @relation("PersonalBuilders", fields: [ownerUserId], references: [id], onDelete: Cascade)
  entity        BuilderEntity           @relation(fields: [entityId], references: [id], onDelete: Cascade)
  poolEntries   BuilderPoolEntry[]
  subscriptions Subscription[]
  feedItems     FeedItem[]
  hubItems      LibraryHubItem[]
  channelPrefs  UserChannelPreference[]

  @@index([ownerUserId, kind])
  @@index([entityId])
  @@index([kind])
  @@index([handle])
  @@index([sourceType])
}

model BuilderEntity {
  id            String                  @id @default(cuid())
  canonicalKey  String                  @unique
  kind          BuilderKind
  name          String
  handle        String?
  bio           String?
  createdAt     DateTime                @default(now())
  updatedAt     DateTime                @updatedAt
  builders      Builder[]
  feedReads     FeedRead[]
  feedFavorites FeedFavorite[]
  digestedItems DigestedItem[]
  channelPrefs  UserChannelPreference[]

  @@index([kind])
  @@index([handle])
}

model UserChannelPreference {
  userId           String
  entityId         String
  primaryBuilderId String
  pinnedByUser     Boolean       @default(false)
  updatedAt        DateTime      @updatedAt
  user             User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  entity           BuilderEntity @relation(fields: [entityId], references: [id], onDelete: Cascade)
  primaryBuilder   Builder       @relation(fields: [primaryBuilderId], references: [id], onDelete: Cascade)

  @@id([userId, entityId])
  @@index([primaryBuilderId])
}

model UserLibraryVisibility {
  userId     String
  hubEntryId String
  hidden     Boolean
  user       User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  hubEntry   LibraryHubEntry @relation(fields: [hubEntryId], references: [id], onDelete: Cascade)

  @@id([userId, hubEntryId])
  @@index([hubEntryId])
}

model BuilderPoolEntry {
  id        String            @id @default(cuid())
  userId    String
  builderId String
  origin    BuilderPoolOrigin
  removedAt DateTime?
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
  user      User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  builder   Builder           @relation(fields: [builderId], references: [id], onDelete: Cascade)

  @@unique([userId, builderId])
  @@index([userId, removedAt])
  @@index([builderId])
}

model LibraryHubEntry {
  id           String                  @id @default(cuid())
  slug         String                  @unique
  name         String
  description  String?
  ownerUserId  String?
  isFeatured   Boolean                 @default(false)
  importCount  Int                     @default(0)
  viewCount    Int                     @default(0)
  createdAt    DateTime                @default(now())
  updatedAt    DateTime                @updatedAt
  owner        User?                   @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)
  items        LibraryHubItem[]
  imports      LibraryImport[]
  visibilities UserLibraryVisibility[]

  @@index([ownerUserId])
  @@index([isFeatured])
}

model LibraryHubItem {
  hubEntryId String
  builderId  String
  createdAt  DateTime        @default(now())
  hubEntry   LibraryHubEntry @relation(fields: [hubEntryId], references: [id], onDelete: Cascade)
  builder    Builder         @relation(fields: [builderId], references: [id], onDelete: Cascade)

  @@id([hubEntryId, builderId])
  @@index([builderId])
}

model LibraryImport {
  userId     String
  hubEntryId String
  createdAt  DateTime        @default(now())
  user       User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  hubEntry   LibraryHubEntry @relation(fields: [hubEntryId], references: [id], onDelete: Cascade)

  @@id([userId, hubEntryId])
  @@index([hubEntryId])
}

model DigestPipelineShare {
  id          String                 @id @default(cuid())
  ownerUserId String
  slug        String                 @unique
  title       String
  description String?
  isPublic    Boolean                @default(true)
  importCount Int                    @default(0)
  viewCount   Int                    @default(0)
  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @updatedAt
  owner       User                   @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)
  imports     DigestPipelineImport[]

  @@unique([ownerUserId])
  @@index([isPublic])
}

model DigestPipelineImport {
  userId     String
  pipelineId String
  createdAt  DateTime            @default(now())
  user       User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  pipeline   DigestPipelineShare @relation(fields: [pipelineId], references: [id], onDelete: Cascade)

  @@id([userId, pipelineId])
  @@index([pipelineId])
}

model Subscription {
  id        String   @id @default(cuid())
  userId    String
  builderId String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  builder   Builder  @relation(fields: [builderId], references: [id], onDelete: Cascade)

  @@unique([userId, builderId])
}

model FeedItem {
  id                          String                       @id @default(cuid())
  builderId                   String?
  kind                        FeedItemKind
  externalId                  String
  title                       String?
  body                        String
  summary                     String?
  url                         String
  publishedAt                 DateTime?
  sourceName                  String?
  fetchTool                   String?
  rawJson                     String?
  createdAt                   DateTime                     @default(now())
  builder                     Builder?                     @relation(fields: [builderId], references: [id], onDelete: SetNull)
  reads                       FeedRead[]
  favorites                   FeedFavorite[]
  digestedItems               DigestedItem[]
  recommendationSnapshotItems RecommendationSnapshotItem[]

  @@unique([builderId, kind, externalId])
  @@index([builderId, publishedAt])
  @@index([publishedAt])
}

model UserFeedPreference {
  userId               String   @id
  /// PublishedAt lookback (days) for digest candidate selection.
  /// Null = runtime default (30 days); the per-user DigestedItem marker dedups
  /// already-covered posts inside that window.
  digestMaxPostAgeDays Int?
  /// Account-wide summary output language selected by the one-time / cron
  /// prompt. Null = use the runtime default language (zh).
  summaryLanguage      String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model FeedRead {
  id         String        @id @default(cuid())
  userId     String
  // Provenance: which FeedItem variant was actually read. Nullable: survives FeedItem deletion.
  feedItemId String?
  // Canonical read identity — keyed at the entity level so reading one channel marks all
  // channel variants of the same post as read.
  entityId   String
  kind       FeedItemKind
  externalId String
  source     String        @default("recommendation")
  readAt     DateTime      @default(now())
  user       User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  feedItem   FeedItem?     @relation(fields: [feedItemId], references: [id], onDelete: SetNull)
  entity     BuilderEntity @relation(fields: [entityId], references: [id], onDelete: Cascade)

  @@unique([userId, entityId, kind, externalId])
  @@index([userId, readAt])
  @@index([userId, entityId])
  @@index([feedItemId])
}

// Per-user saved post list for the Home Favorites tab. Mirrors FeedRead's
// canonical identity so saving one channel variant saves the post across
// imported / personal channel variants of the same source item.
model FeedFavorite {
  id           String        @id @default(cuid())
  userId       String
  feedItemId   String?
  entityId     String
  kind         FeedItemKind
  externalId   String
  favoritedAt  DateTime      @default(now())
  markedReadAt DateTime?
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  feedItem     FeedItem?     @relation(fields: [feedItemId], references: [id], onDelete: SetNull)
  entity       BuilderEntity @relation(fields: [entityId], references: [id], onDelete: Cascade)

  @@unique([userId, entityId, kind, externalId])
  @@index([userId, favoritedAt])
  @@index([userId, markedReadAt])
  @@index([userId, entityId])
  @@index([feedItemId])
}

// Per-user record that a post has already been included in (presented to) a
// digest. Mirrors FeedRead: keyed at the canonical content identity
// (entityId + kind + externalId) so marking one channel covers every channel
// variant of the same post, and scoped per user because the same content is
// shared across users' channels. Digest candidate selection excludes posts
// the user already has a DigestedItem for (unless the override toggle is on).
model DigestedItem {
  id         String        @id @default(cuid())
  userId     String
  // Provenance: which FeedItem variant was presented. Nullable: survives deletion.
  feedItemId String?
  entityId   String
  kind       FeedItemKind
  externalId String
  // Provenance: which digest first included it. Nullable: survives digest deletion.
  digestId   String?
  digestedAt DateTime      @default(now())
  user       User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  feedItem   FeedItem?     @relation(fields: [feedItemId], references: [id], onDelete: SetNull)
  entity     BuilderEntity @relation(fields: [entityId], references: [id], onDelete: Cascade)

  @@unique([userId, entityId, kind, externalId])
  @@index([userId, digestedAt])
  @@index([feedItemId])
}

model RecommendationSnapshot {
  id        String                       @id @default(cuid())
  userId    String
  reason    String                       @default("recommendation")
  createdAt DateTime                     @default(now())
  user      User                         @relation(fields: [userId], references: [id], onDelete: Cascade)
  items     RecommendationSnapshotItem[]

  @@index([userId, createdAt])
}

model RecommendationSnapshotItem {
  snapshotId String
  feedItemId String
  rank       Int
  score      Float
  reasons    String
  createdAt  DateTime               @default(now())
  snapshot   RecommendationSnapshot @relation(fields: [snapshotId], references: [id], onDelete: Cascade)
  feedItem   FeedItem               @relation(fields: [feedItemId], references: [id], onDelete: Cascade)

  @@id([snapshotId, feedItemId])
  @@index([feedItemId])
  @@index([snapshotId, rank])
}

model Digest {
  id              String       @id @default(cuid())
  userId          String
  title           String
  content         String
  headlineSummary String?
  periodStart     DateTime
  periodEnd       DateTime
  language        String       @default("zh")
  status          DigestStatus @default(SYNCED)
  source          String       @default("skill")
  itemCount       Int          @default(0)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  user            User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

/// Diagnostic record of one digest generation attempt — the digest analogue of
/// LibraryFetchRun. Created at `prepare` (context fetch) with a snapshot of the
/// candidate funnel the agent was handed, then updated to "synced" when the
/// digest is posted back. Self-contained: the candidate/subscription snapshots
/// and includedKeys are stored inline so the funnel survives deletion of the
/// produced Digest or its DigestedItem markers (digestId is a soft link, no FK).
model DigestRun {
  id                String    @id @default(cuid())
  userId            String
  /// "prepared" (context fetched, no digest synced yet) | "synced".
  status            String    @default("prepared")
  source            String    @default("skill")
  preparedAt        DateTime  @default(now())
  syncedAt          DateTime?
  // --- Window snapshot (from digestWindow at prepare time) ---
  /// PublishedAt lookback floor captured when prepare ran. Null is retained for
  /// historical runs and compatibility; current prepares default to 30 days.
  lookbackCutoff    DateTime?
  maxPostAgeDays    Int?
  lastDigestAt      DateTime?
  regenerate        Boolean   @default(false)
  // --- Funnel counts ---
  subscriptionCount Int       @default(0)
  candidateCount    Int       @default(0)
  /// Set at sync = number of candidates the agent actually presented.
  includedCount     Int?
  // --- Snapshots (durable; independent of Digest / DigestedItem) ---
  /// [{ entityId, kind, externalId, feedItemId, title, url, source, publishedAt }]
  candidates        Json
  /// [{ entityId, name }] — the subscribed entities at run time, so the log can
  /// show which followed sources stayed silent.
  subscriptions     Json
  /// ["entityId:kind:externalId", ...] of the presented posts; set at sync.
  /// A candidate not in this set is "eligible but dropped" by the editorial step.
  includedKeys      Json?
  // --- Outcome (soft link; nullable so the run survives digest deletion) ---
  digestId          String?
  digestTitle       String?
  language          String?
  jobRunId          String?
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, preparedAt(sort: Desc)])
  @@index([userId, jobRunId])
}

model AgentToken {
  id              String         @id @default(cuid())
  userId          String
  name            String
  tokenHash       String         @unique
  /// Legacy plaintext column kept only so old rows still resolve until a
  /// backfill+drop migration completes. New tokens MUST set
  /// `tokenCiphertext` instead and leave `tokenValue` null.
  tokenValue      String?
  /// AES-256-GCM ciphertext of the raw token, encoded as
  /// `iv.tag.ciphertext` (all base64url). The encryption key is derived
  /// from `NEXTAUTH_SECRET` so a DB dump alone is not enough to recover
  /// any token.
  tokenCiphertext String?
  lastUsedAt      DateTime?
  lastIp          String?
  lastUserAgent   String?
  /// CLI-reported machine identity (best-effort; user can fake these
  /// headers, but they're meant to help the user recognize their own
  /// machines in the Settings UI, not as an auth signal).
  lastHostname    String?
  lastPlatform    String?
  lastUser        String?
  createdAt       DateTime       @default(now())
  revokedAt       DateTime?
  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  exchangeCodes   ExchangeCode[]

  @@index([userId])
}

model ExchangeCode {
  id           String     @id @default(cuid())
  code         String     @unique
  agentTokenId String
  expiresAt    DateTime
  usedAt       DateTime?
  createdAt    DateTime   @default(now())
  agentToken   AgentToken @relation(fields: [agentTokenId], references: [id], onDelete: Cascade)

  @@index([agentTokenId])
}

/// Admin-editable per-source-type configuration. The code-bound fields
/// (builderKind, feedItemKinds, urlPatterns, fetch fn) still live in
/// config/sources.json; this table is the runtime source of truth for
/// every safe-to-hot-edit attribute. Seeded from sources.json +
/// digest-prompts on app startup so the table is never empty.
model SourceTypeConfig {
  sourceId           String   @id
  label              String
  agentDefaultStatus String   @default("ready")
  defaultFetchDays   Int      @default(30)
  defaultFetchLimit  Int      @default(3)
  contentQuality     Json
  summaryPromptBody  String
  /// Optional per-source fetch prompt. When non-empty, this prompt is
  /// surfaced to the agent in fallback fetch tasks so it can choose how
  /// to acquire content (e.g. for podcast: try show notes first, else
  /// download audio + Whisper transcribe). When empty, the CLI's
  /// deterministic fetch behavior is the only thing that runs.
  fetchPromptBody    String?
  summaryStyle       String
  /// Legacy compatibility fields. Runtime language comes from
  /// UserFeedPreference.summaryLanguage; length hint is unused.
  summaryLanguage    String   @default("zh")
  summaryLengthHint  String?
  updatedAt          DateTime @updatedAt
  updatedBy          String?
}

/// Singleton (id="global") that holds digest-level prompts. digestIntro and
/// digestOrder are legacy compatibility fields; current digest assembly is
/// deterministic and uses headlinePrompt / perSourceSummaryPrompt / translate.
model DigestConfig {
  id                     String   @id @default("global")
  digestIntro            String
  headlinePrompt         String
  perSourceSummaryPrompt String
  translate              String
  digestOrder            Json
  commonFetchRules       String
  commonSummaryRules     String
  updatedAt              DateTime @updatedAt
  updatedBy              String?
}

/// Per-user copy of a SourceTypeConfig. Materialized (full copy) from the
/// SourceTypeConfig "default" template on first touch; thereafter the user
/// edits their own row. Mirrors every SourceTypeConfig field.
model UserSourceTypeConfig {
  userId             String
  sourceId           String
  label              String
  agentDefaultStatus String   @default("ready")
  defaultFetchDays   Int      @default(30)
  defaultFetchLimit  Int      @default(3)
  contentQuality     Json
  summaryPromptBody  String
  fetchPromptBody    String?
  summaryStyle       String
  /// Legacy compatibility fields. Runtime language comes from
  /// UserFeedPreference.summaryLanguage; length hint is unused.
  summaryLanguage    String   @default("zh")
  summaryLengthHint  String?
  updatedAt          DateTime @updatedAt
  updatedBy          String?
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, sourceId])
  @@index([userId])
}

/// Per-user copy of the DigestConfig singleton. Materialized from the
/// DigestConfig "default" template on first touch.
model UserDigestConfig {
  userId                 String   @id
  digestIntro            String
  headlinePrompt         String
  perSourceSummaryPrompt String
  translate              String
  digestOrder            Json
  commonFetchRules       String
  commonSummaryRules     String
  updatedAt              DateTime @updatedAt
  updatedBy              String?
  user                   User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum BuilderKind {
  X
  BLOG
  PODCAST
  WEBSITE
}

enum BuilderPoolOrigin {
  PERSONAL_SYNC
  HUB_IMPORT
}

enum FeedItemKind {
  TWEET
  BLOG_POST
  PODCAST_EPISODE
}

enum DigestStatus {
  SYNCED
}

enum FetchStatus {
  IDLE
  RUNNING
  OK
  ERROR
  STALE
}
