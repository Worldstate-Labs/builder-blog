// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                 String              @id @default(cuid())
  name               String?
  email              String?             @unique
  emailVerified      DateTime?
  image              String?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  accounts           Account[]
  sessions           Session[]
  subscriptions      Subscription[]
  digests            Digest[]
  agentTokens        AgentToken[]
  deviceLogins       DeviceLogin[]
  personalBuilders   Builder[]           @relation("PersonalBuilders")
  builderPoolEntries BuilderPoolEntry[]
  builderCrawls      UserBuilderCrawl[]
  libraryHubEntries  LibraryHubEntry[]
  libraryImports     LibraryImport[]
  feedPreference     UserFeedPreference?
  feedReads          FeedRead[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Builder {
  id            String             @id @default(cuid())
  scope         BuilderScope       @default(CENTRAL)
  ownerUserId   String?
  kind          BuilderKind        @default(X)
  name          String
  handle        String?
  canonicalKey  String
  libraryKey    String             @unique
  sourceType    String             @default("auto")
  sourceUrl     String?
  crawlUrl      String?
  bio           String?
  addedByUserId String?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  owner         User?              @relation("PersonalBuilders", fields: [ownerUserId], references: [id], onDelete: Cascade)
  poolEntries   BuilderPoolEntry[]
  subscriptions Subscription[]
  feedItems     FeedItem[]
  userCrawls    UserBuilderCrawl[]
  hubItems      LibraryHubItem[]

  @@index([scope, kind])
  @@index([ownerUserId, kind])
  @@index([kind])
  @@index([handle])
  @@index([sourceType])
}

model BuilderPoolEntry {
  id        String            @id @default(cuid())
  userId    String
  builderId String
  origin    BuilderPoolOrigin
  removedAt DateTime?
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
  user      User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  builder   Builder           @relation(fields: [builderId], references: [id], onDelete: Cascade)

  @@unique([userId, builderId])
  @@index([userId, removedAt])
  @@index([builderId])
}

model LibraryHubEntry {
  id          String           @id @default(cuid())
  kind        LibraryHubKind
  slug        String           @unique
  name        String
  description String?
  ownerUserId String?
  importCount Int              @default(0)
  viewCount   Int              @default(0)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  owner       User?            @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)
  items       LibraryHubItem[]
  imports     LibraryImport[]

  @@index([kind])
  @@index([ownerUserId])
}

model LibraryHubItem {
  hubEntryId String
  builderId  String
  createdAt  DateTime        @default(now())
  hubEntry   LibraryHubEntry @relation(fields: [hubEntryId], references: [id], onDelete: Cascade)
  builder    Builder         @relation(fields: [builderId], references: [id], onDelete: Cascade)

  @@id([hubEntryId, builderId])
  @@index([builderId])
}

model LibraryImport {
  userId     String
  hubEntryId String
  createdAt  DateTime        @default(now())
  user       User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  hubEntry   LibraryHubEntry @relation(fields: [hubEntryId], references: [id], onDelete: Cascade)

  @@id([userId, hubEntryId])
  @@index([hubEntryId])
}

model UserBuilderCrawl {
  id            String    @id @default(cuid())
  userId        String
  builderId     String
  lastCrawledAt DateTime  @default(now())
  lastForcedAt  DateTime?
  itemCount     Int       @default(0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  builder       Builder   @relation(fields: [builderId], references: [id], onDelete: Cascade)

  @@unique([userId, builderId])
  @@index([userId, lastCrawledAt])
  @@index([builderId])
}

model Subscription {
  id        String   @id @default(cuid())
  userId    String
  builderId String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  builder   Builder  @relation(fields: [builderId], references: [id], onDelete: Cascade)

  @@unique([userId, builderId])
}

model FeedItem {
  id           String       @id @default(cuid())
  builderId    String?
  kind         FeedItemKind
  externalId   String
  title        String?
  body         String
  url          String
  publishedAt  DateTime?
  sourceName   String?
  crawlingTool String?
  rawJson      String?
  createdAt    DateTime     @default(now())
  builder      Builder?     @relation(fields: [builderId], references: [id], onDelete: SetNull)
  reads        FeedRead[]

  @@unique([builderId, kind, externalId])
  @@index([builderId, publishedAt])
  @@index([publishedAt])
}

model UserFeedPreference {
  userId                    String          @id
  digestFrequency           DigestFrequency @default(DAILY)
  digestCustomFrequencyDays Int?
  digestMaxPostAgeDays      Int             @default(90)
  recommendationProfile     String?
  createdAt                 DateTime        @default(now())
  updatedAt                 DateTime        @updatedAt
  user                      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model FeedRead {
  id         String   @id @default(cuid())
  userId     String
  feedItemId String
  source     String   @default("recommendation")
  readAt     DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  feedItem   FeedItem @relation(fields: [feedItemId], references: [id], onDelete: Cascade)

  @@unique([userId, feedItemId])
  @@index([userId, readAt])
  @@index([feedItemId])
}

model Digest {
  id          String       @id @default(cuid())
  userId      String
  title       String
  content     String
  periodStart DateTime
  periodEnd   DateTime
  language    String       @default("zh")
  status      DigestStatus @default(SYNCED)
  source      String       @default("skill")
  itemCount   Int          @default(0)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model AgentToken {
  id         String    @id @default(cuid())
  userId     String
  name       String
  tokenHash  String    @unique
  lastUsedAt DateTime?
  createdAt  DateTime  @default(now())
  revokedAt  DateTime?
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model DeviceLogin {
  id           String    @id @default(cuid())
  code         String    @unique
  userId       String?
  agentTokenId String?
  issuedToken  String?
  expiresAt    DateTime
  approvedAt   DateTime?
  createdAt    DateTime  @default(now())
  user         User?     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([code])
}

enum BuilderKind {
  X
  BLOG
  PODCAST
  WEBSITE
}

enum BuilderScope {
  CENTRAL
  PERSONAL
}

enum BuilderPoolOrigin {
  CENTRAL_DEFAULT
  PERSONAL_SYNC
  HUB_IMPORT
}

enum LibraryHubKind {
  CENTRAL
  PERSONAL
}

enum FeedItemKind {
  TWEET
  BLOG_POST
  PODCAST_EPISODE
}

enum DigestStatus {
  SYNCED
  GENERATED
}

enum DigestFrequency {
  DAILY
  WEEKLY
  CUSTOM
}
