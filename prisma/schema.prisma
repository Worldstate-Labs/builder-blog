// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                      String                   @id @default(cuid())
  name                    String?
  email                   String?                  @unique
  emailVerified           DateTime?
  image                   String?
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
  accounts                Account[]
  sessions                Session[]
  subscriptions           Subscription[]
  digests                 Digest[]
  agentTokens             AgentToken[]
  personalBuilders        Builder[]                @relation("PersonalBuilders")
  builderPoolEntries      BuilderPoolEntry[]
  libraryHubEntries       LibraryHubEntry[]
  libraryImports          LibraryImport[]
  feedPreference          UserFeedPreference?
  feedReads               FeedRead[]
  recommendationSnapshots RecommendationSnapshot[]
  channelPreferences      UserChannelPreference[]
  libraryVisibilities     UserLibraryVisibility[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Builder {
  id            String                  @id @default(cuid())
  ownerUserId   String
  kind          BuilderKind             @default(X)
  name          String
  handle        String?
  canonicalKey  String
  libraryKey    String                  @unique
  sourceType    String                  @default("auto")
  sourceUrl     String?
  crawlUrl      String?
  bio           String?
  addedByUserId String?
  entityId      String
  lastCrawledAt DateTime?
  lastForcedAt  DateTime?
  itemCount     Int                     @default(0)
  status        CrawlStatus             @default(IDLE)
  lastError     String?
  createdAt     DateTime                @default(now())
  updatedAt     DateTime                @updatedAt
  owner         User                    @relation("PersonalBuilders", fields: [ownerUserId], references: [id], onDelete: Cascade)
  entity        BuilderEntity           @relation(fields: [entityId], references: [id], onDelete: Cascade)
  poolEntries   BuilderPoolEntry[]
  subscriptions Subscription[]
  feedItems     FeedItem[]
  hubItems      LibraryHubItem[]
  channelPrefs  UserChannelPreference[]

  @@index([ownerUserId, kind])
  @@index([entityId])
  @@index([kind])
  @@index([handle])
  @@index([sourceType])
}

model BuilderEntity {
  id           String                  @id @default(cuid())
  canonicalKey String                  @unique
  kind         BuilderKind
  name         String
  handle       String?
  bio          String?
  createdAt    DateTime                @default(now())
  updatedAt    DateTime                @updatedAt
  builders     Builder[]
  feedReads    FeedRead[]
  channelPrefs UserChannelPreference[]

  @@index([kind])
  @@index([handle])
}

model UserChannelPreference {
  userId           String
  entityId         String
  primaryBuilderId String
  pinnedByUser     Boolean       @default(false)
  updatedAt        DateTime      @updatedAt
  user             User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  entity           BuilderEntity @relation(fields: [entityId], references: [id], onDelete: Cascade)
  primaryBuilder   Builder       @relation(fields: [primaryBuilderId], references: [id], onDelete: Cascade)

  @@id([userId, entityId])
  @@index([primaryBuilderId])
}

model UserLibraryVisibility {
  userId     String
  hubEntryId String
  hidden     Boolean         @default(true)
  user       User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  hubEntry   LibraryHubEntry @relation(fields: [hubEntryId], references: [id], onDelete: Cascade)

  @@id([userId, hubEntryId])
  @@index([hubEntryId])
}

model BuilderPoolEntry {
  id        String            @id @default(cuid())
  userId    String
  builderId String
  origin    BuilderPoolOrigin
  removedAt DateTime?
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
  user      User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  builder   Builder           @relation(fields: [builderId], references: [id], onDelete: Cascade)

  @@unique([userId, builderId])
  @@index([userId, removedAt])
  @@index([builderId])
}

model LibraryHubEntry {
  id           String                  @id @default(cuid())
  slug         String                  @unique
  name         String
  description  String?
  ownerUserId  String?
  isFeatured   Boolean                 @default(false)
  importCount  Int                     @default(0)
  viewCount    Int                     @default(0)
  createdAt    DateTime                @default(now())
  updatedAt    DateTime                @updatedAt
  owner        User?                   @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)
  items        LibraryHubItem[]
  imports      LibraryImport[]
  visibilities UserLibraryVisibility[]

  @@index([ownerUserId])
  @@index([isFeatured])
}

model LibraryHubItem {
  hubEntryId String
  builderId  String
  createdAt  DateTime        @default(now())
  hubEntry   LibraryHubEntry @relation(fields: [hubEntryId], references: [id], onDelete: Cascade)
  builder    Builder         @relation(fields: [builderId], references: [id], onDelete: Cascade)

  @@id([hubEntryId, builderId])
  @@index([builderId])
}

model LibraryImport {
  userId     String
  hubEntryId String
  createdAt  DateTime        @default(now())
  user       User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  hubEntry   LibraryHubEntry @relation(fields: [hubEntryId], references: [id], onDelete: Cascade)

  @@id([userId, hubEntryId])
  @@index([hubEntryId])
}

model Subscription {
  id        String   @id @default(cuid())
  userId    String
  builderId String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  builder   Builder  @relation(fields: [builderId], references: [id], onDelete: Cascade)

  @@unique([userId, builderId])
}

model FeedItem {
  id                          String                       @id @default(cuid())
  builderId                   String?
  kind                        FeedItemKind
  externalId                  String
  title                       String?
  body                        String
  summary                     String?
  url                         String
  publishedAt                 DateTime?
  sourceName                  String?
  crawlingTool                String?
  rawJson                     String?
  createdAt                   DateTime                     @default(now())
  builder                     Builder?                     @relation(fields: [builderId], references: [id], onDelete: SetNull)
  reads                       FeedRead[]
  recommendationSnapshotItems RecommendationSnapshotItem[]

  @@unique([builderId, kind, externalId])
  @@index([builderId, publishedAt])
  @@index([publishedAt])
}

model UserFeedPreference {
  userId                    String          @id
  digestFrequency           DigestFrequency @default(DAILY)
  digestCustomFrequencyDays Int?
  digestMaxPostAgeDays      Int             @default(90)
  recommendationProfile     String?
  createdAt                 DateTime        @default(now())
  updatedAt                 DateTime        @updatedAt
  user                      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model FeedRead {
  id         String        @id @default(cuid())
  userId     String
  // Provenance: which FeedItem variant was actually read. Nullable: survives FeedItem deletion.
  feedItemId String?
  // Canonical read identity — keyed at the entity level so reading one channel marks all
  // channel variants of the same post as read.
  entityId   String
  kind       FeedItemKind
  externalId String
  source     String        @default("recommendation")
  readAt     DateTime      @default(now())
  user       User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  feedItem   FeedItem?     @relation(fields: [feedItemId], references: [id], onDelete: SetNull)
  entity     BuilderEntity @relation(fields: [entityId], references: [id], onDelete: Cascade)

  @@unique([userId, entityId, kind, externalId])
  @@index([userId, readAt])
  @@index([userId, entityId])
  @@index([feedItemId])
}

model RecommendationSnapshot {
  id        String                       @id @default(cuid())
  userId    String
  reason    String                       @default("recommendation")
  createdAt DateTime                     @default(now())
  user      User                         @relation(fields: [userId], references: [id], onDelete: Cascade)
  items     RecommendationSnapshotItem[]

  @@index([userId, createdAt])
}

model RecommendationSnapshotItem {
  snapshotId String
  feedItemId String
  rank       Int
  score      Float
  reasons    String
  createdAt  DateTime               @default(now())
  snapshot   RecommendationSnapshot @relation(fields: [snapshotId], references: [id], onDelete: Cascade)
  feedItem   FeedItem               @relation(fields: [feedItemId], references: [id], onDelete: Cascade)

  @@id([snapshotId, feedItemId])
  @@index([feedItemId])
  @@index([snapshotId, rank])
}

model Digest {
  id          String       @id @default(cuid())
  userId      String
  title       String
  content     String
  periodStart DateTime
  periodEnd   DateTime
  language    String       @default("zh")
  status      DigestStatus @default(SYNCED)
  source      String       @default("skill")
  itemCount   Int          @default(0)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model AgentToken {
  id              String         @id @default(cuid())
  userId          String
  name            String
  tokenHash       String         @unique
  /// Legacy plaintext column kept only so old rows still resolve until a
  /// backfill+drop migration completes. New tokens MUST set
  /// `tokenCiphertext` instead and leave `tokenValue` null.
  tokenValue      String?
  /// AES-256-GCM ciphertext of the raw token, encoded as
  /// `iv.tag.ciphertext` (all base64url). The encryption key is derived
  /// from `NEXTAUTH_SECRET` so a DB dump alone is not enough to recover
  /// any token.
  tokenCiphertext String?
  lastUsedAt      DateTime?
  lastIp          String?
  lastUserAgent   String?
  createdAt       DateTime       @default(now())
  revokedAt       DateTime?
  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  exchangeCodes   ExchangeCode[]

  @@index([userId])
}

model ExchangeCode {
  id           String     @id @default(cuid())
  code         String     @unique
  agentTokenId String
  expiresAt    DateTime
  usedAt       DateTime?
  createdAt    DateTime   @default(now())
  agentToken   AgentToken @relation(fields: [agentTokenId], references: [id], onDelete: Cascade)

  @@index([agentTokenId])
}

enum BuilderKind {
  X
  BLOG
  PODCAST
  WEBSITE
}

enum BuilderPoolOrigin {
  PERSONAL_SYNC
  HUB_IMPORT
}

enum FeedItemKind {
  TWEET
  BLOG_POST
  PODCAST_EPISODE
}

enum DigestStatus {
  SYNCED
  GENERATED
}

enum DigestFrequency {
  DAILY
  WEEKLY
  CUSTOM
}

enum CrawlStatus {
  IDLE
  RUNNING
  OK
  ERROR
  STALE
}
